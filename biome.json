{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"files": {
		"includes": ["**", "!.next"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true
	},
	"javascript": {
		"formatter": {
			"enabled": true,
			"lineWidth": 80,
			"semicolons": "always",
			"trailingCommas": "none",
			"indentWidth": 2,
			"indentStyle": "tab",
			"arrowParentheses": "asNeeded",
			"quoteStyle": "double"
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentWidth": 2
		},
		"linter": {
			"enabled": true
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
